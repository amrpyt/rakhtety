# Copy this file to .env on the server.
# Never commit the real .env file.

COMPOSE_PROJECT_NAME=rakhtety

# Public hostnames
FRAPPE_HOSTNAME=frappe-rakhtety.coderaai.com
NEXT_HOSTNAME=rakhtety.coderaai.com
LETSENCRYPT_EMAIL=admin@coderaai.com

# Images
RAKHTETY_FRAPPE_IMAGE=rakhtety-frappe:v16.16.0-prod
RAKHTETY_NEXT_IMAGE=rakhtety-next:prod

# Frappe site
SITE_NAME=frappe-rakhtety.coderaai.com
ADMIN_PASSWORD=change-me
INSTALL_APPS=erpnext,rakhtety_frappe

# Database
DB_ROOT_PASSWORD=change-me
MYSQL_DATABASE=_site_db
MYSQL_USER=frappe
MYSQL_PASSWORD=change-me

# Runtime
SOCKETIO_PORT=9000
UPSTREAM_REAL_IP_ADDRESS=127.0.0.1
UPSTREAM_REAL_IP_HEADER=X-Forwarded-For
UPSTREAM_REAL_IP_RECURSIVE=off
