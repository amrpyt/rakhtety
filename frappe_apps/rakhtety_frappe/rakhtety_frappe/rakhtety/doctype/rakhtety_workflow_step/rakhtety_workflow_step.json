{
  "actions": [],
  "allow_import": 1,
  "allow_rename": 1,
  "autoname": "field:title",
  "doctype": "DocType",
  "engine": "InnoDB",
  "field_order": ["title", "workflow", "step_order", "step_name_ar", "status", "assigned_to", "requires_document", "required_document_uploaded", "government_fees", "office_profit"],
  "fields": [
    {"fieldname": "title", "fieldtype": "Data", "in_list_view": 1, "label": "Step Title", "reqd": 1, "unique": 1},
    {"fieldname": "workflow", "fieldtype": "Link", "in_list_view": 1, "in_standard_filter": 1, "label": "Workflow", "options": "Rakhtety Workflow", "reqd": 1, "search_index": 1},
    {"fieldname": "step_order", "fieldtype": "Int", "in_list_view": 1, "label": "Step Order"},
    {"fieldname": "step_name_ar", "fieldtype": "Data", "in_list_view": 1, "label": "Arabic Step Name"},
    {"default": "pending", "fieldname": "status", "fieldtype": "Select", "in_list_view": 1, "in_standard_filter": 1, "label": "Status", "options": "pending\nin_progress\ncompleted"},
    {"fieldname": "assigned_to", "fieldtype": "Link", "in_standard_filter": 1, "label": "Assigned To", "options": "Rakhtety Employee", "search_index": 1},
    {"default": "0", "fieldname": "requires_document", "fieldtype": "Check", "label": "Requires Document"},
    {"default": "0", "fieldname": "required_document_uploaded", "fieldtype": "Check", "label": "Required Document Uploaded"},
    {"fieldname": "government_fees", "fieldtype": "Currency", "label": "Government Fees"},
    {"fieldname": "office_profit", "fieldtype": "Currency", "label": "Office Profit"}
  ],
  "module": "Rakhtety",
  "name": "Rakhtety Workflow Step",
  "naming_rule": "By Fieldname",
  "permissions": [
    {"create": 1, "delete": 1, "email": 1, "export": 1, "print": 1, "read": 1, "report": 1, "role": "System Manager", "share": 1, "write": 1},
    {"create": 1, "delete": 1, "email": 1, "export": 1, "print": 1, "read": 1, "report": 1, "role": "Rakhtety Admin", "share": 1, "write": 1},
    {"create": 1, "email": 1, "export": 1, "print": 1, "read": 1, "report": 1, "role": "Rakhtety Manager", "share": 1, "write": 1},
    {"email": 1, "print": 1, "read": 1, "report": 1, "role": "Rakhtety Employee", "write": 1}
  ],
  "sort_field": "step_order",
  "sort_order": "ASC",
  "title_field": "title",
  "track_changes": 1
}
